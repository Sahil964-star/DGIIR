// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
  previewFeatures = ["fullTextSearchPostgres"]
}

datasource db {
  provider = "postgresql"
}

// ─── ENUMS ────────────────────────────────────────────────────────

enum Role {
  CITIZEN
  FIELD_OFFICER
  OPERATIONS
  DEPARTMENT_HEAD
  CHIEF_MINISTER
  SUPER_ADMIN
}

enum ComplaintStatus {
  PENDING
  UNDER_REVIEW
  ASSIGNED
  IN_PROGRESS
  RESOLVED
  VERIFICATION_PENDING
  CLOSED
  REOPENED
  REJECTED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum NotificationType {
  STATUS_UPDATE
  ASSIGNMENT
  SLA_BREACH
  ESCALATION
  CITIZEN_FEEDBACK
  SYSTEM_ALERT
}

enum MediaType {
  CITIZEN_EVIDENCE
  OFFICER_PROOF
  BEFORE_PHOTO
  AFTER_PHOTO
}

// ─── CORE ENTITIES ────────────────────────────────────────────────

model User {
  id            String   @id @default(uuid())
  email         String?  @unique
  phone         String?  @unique
  passwordHash  String?  // Optional for Citizens using OTP
  twoFactorSec  String?  // 2FA Secret for CM/Admin
  name          String
  role          Role     @default(CITIZEN)
  isActive      Boolean  @default(true)
  deviceToken   String?  // Firebase Cloud Messaging (Push Notifications)
  
  departmentId  String?
  department    Department? @relation(fields: [departmentId], references: [id])
  
  districtId    String?
  district      District?   @relation(fields: [districtId], references: [id])

  complaintsFiled   Complaint[] @relation("CitizenComplaints")
  complaintsAssigned Complaint[] @relation("OfficerComplaints")
  
  escalationsTriggered Escalation[] @relation("EscalatedFrom")
  escalationsReceived  Escalation[] @relation("EscalatedTo")

  events            ComplaintEvent[]
  media             Media[]
  notifications     Notification[]
  otps              OtpVerification[]
  auditLogs         AuditLog[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime? // Soft Delete

  @@index([role, districtId])
}

model District {
  id          String   @id @default(uuid())
  name        String   @unique 
  code        String   @unique 
  
  users       User[]
  complaints  Complaint[]
}

model Department {
  id          String   @id @default(uuid())
  name        String   @unique 
  code        String   @unique 
  
  users       User[]
  complaints  Complaint[]
  categories  Category[]
  
  deletedAt   DateTime? // Soft Delete
}

model Category {
  id           String   @id @default(uuid())
  name         String   @unique 
  
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id])
  
  slaConfig    SlaConfiguration?
  complaints   Complaint[]

  @@index([departmentId])
}

model SlaConfiguration {
  id            String   @id @default(uuid())
  categoryId    String   @unique
  category      Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  
  resolveHours  Int      
  escalationTarget Role  
  priorityRules Json     
  
  updatedAt     DateTime @updatedAt
}

model Complaint {
  id          String          @id @default(uuid())
  complaintNo String          @unique 
  title       String
  description String
  status      ComplaintStatus @default(PENDING)
  priority    Priority        @default(MEDIUM)
  isOverdue   Boolean         @default(false)
  
  // Location Intelligence
  address     String
  latitude    Float?
  longitude   Float?
  ward        String?         // Future-proof: Local ward name/number
  zone        String?         // Future-proof: Local municipal zone

  // Timestamps
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  assignedAt  DateTime?
  resolvedAt  DateTime?
  closedAt    DateTime?
  slaBreachAt DateTime? 
  deletedAt   DateTime? // Soft Delete
  
  // Foreign Keys
  citizenId   String
  citizen     User      @relation("CitizenComplaints", fields: [citizenId], references: [id])
  
  officerId   String?
  officer     User?     @relation("OfficerComplaints", fields: [officerId], references: [id])
  
  districtId  String
  district    District  @relation(fields: [districtId], references: [id])
  
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])
  
  categoryId  String
  category    Category  @relation(fields: [categoryId], references: [id])
  
  // Relations
  events       ComplaintEvent[]
  media        Media[]
  escalations  Escalation[]
  verification ComplaintVerification?

  // Required Indexes for Analytics & Operations
  @@index([status, createdAt])
  @@index([districtId, status])
  @@index([departmentId, isOverdue])
  @@index([slaBreachAt])
  @@index([priority])
}

// ─── WORKFLOW & AUDIT ENTITIES ────────────────────────────────────

model ComplaintVerification {
  id          String   @id @default(uuid())
  complaintId String   @unique
  complaint   Complaint @relation(fields: [complaintId], references: [id], onDelete: Cascade)
  
  status      VerificationStatus @default(PENDING)
  feedback    String?
  rating      Int?     // 1-5 scale
  
  verifiedAt  DateTime?
  createdAt   DateTime @default(now())
}

model Escalation {
  id             String   @id @default(uuid())
  complaintId    String
  complaint      Complaint @relation(fields: [complaintId], references: [id], onDelete: Cascade)
  
  escalatedFromId String
  escalatedFrom   User    @relation("EscalatedFrom", fields: [escalatedFromId], references: [id])
  
  escalatedToId   String
  escalatedTo     User    @relation("EscalatedTo", fields: [escalatedToId], references: [id])
  
  reason         String
  createdAt      DateTime @default(now())

  @@index([complaintId])
}

model ComplaintEvent {
  id          String   @id @default(uuid())
  action      String   
  oldStatus   ComplaintStatus?
  newStatus   ComplaintStatus?
  comments    String?
  
  complaintId String
  complaint   Complaint @relation(fields: [complaintId], references: [id], onDelete: Cascade)
  
  actorId     String
  actor       User      @relation(fields: [actorId], references: [id])
  
  createdAt   DateTime  @default(now())
}

model Media {
  id          String   @id @default(uuid())
  url         String   
  publicId    String   
  type        MediaType
  
  complaintId String
  complaint   Complaint @relation(fields: [complaintId], references: [id], onDelete: Cascade)
  
  uploadedById String
  uploadedBy   User     @relation(fields: [uploadedById], references: [id])
  
  createdAt   DateTime @default(now())
}

model AuditLog {
  id          String   @id @default(uuid())
  actorId     String
  actor       User     @relation(fields: [actorId], references: [id])
  
  action      String   
  entityType  String
  entityId    String
  details     Json
  ipAddress   String?
  
  timestamp   DateTime @default(now())

  @@index([entityType, entityId])
  @@index([timestamp])
}

// ─── SYSTEM ENTITIES ──────────────────────────────────────────────

model Notification {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  type        NotificationType
  title       String
  message     String
  isRead      Boolean  @default(false)
  linkTarget  String?  
  
  createdAt   DateTime @default(now())

  @@index([userId, isRead])
}

model OtpVerification {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  otpHash     String
  expiresAt   DateTime
  isUsed      Boolean  @default(false)
  
  createdAt   DateTime @default(now())

  @@index([userId, isUsed])
}

model AnalyticsSnapshot {
  id                String   @id @default(uuid())
  timestamp         DateTime @default(now())
  
  totalComplaints   Int
  resolved          Int
  inProgress        Int
  overdue           Int
  
  // Advanced Analytics Payloads
  districtMetrics   Json     
  departmentMetrics Json     
  categoryMetrics   Json     
  resolutionTrends  Json     
  
  // Satisfaction Analytics
  averageRating           Float?
  citizenSatisfactionScore Float?
  verificationApprovalRate Float?

  // Officer Performance Analytics
  officerMetrics          Json?    
  
  @@index([timestamp])
}
