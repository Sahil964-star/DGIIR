generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearchPostgres"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String            @id @default(uuid())
  email                String?           @unique
  phone                String?           @unique
  passwordHash         String?
  twoFactorSec         String?
  name                 String
  role                 Role              @default(CITIZEN)
  isActive             Boolean           @default(true)
  deviceToken          String?
  departmentId         String?
  districtId           String?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  deletedAt            DateTime?
  auditLogs            AuditLog[]
  complaintsFiled      Complaint[]       @relation("CitizenComplaints")
  complaintsAssigned   Complaint[]       @relation("OfficerComplaints")
  events               ComplaintEvent[]
  escalationsTriggered Escalation[]      @relation("EscalatedFrom")
  escalationsReceived  Escalation[]      @relation("EscalatedTo")
  media                Media[]
  notifications        Notification[]
  otps                 OtpVerification[]
  department           Department?       @relation(fields: [departmentId], references: [id])
  district             District?         @relation(fields: [districtId], references: [id])

  @@index([role, districtId])
}

model District {
  id         String      @id @default(uuid())
  name       String      @unique
  code       String      @unique
  complaints Complaint[]
  users      User[]
}

model Department {
  id         String      @id @default(uuid())
  name       String      @unique
  code       String      @unique
  deletedAt  DateTime?
  categories Category[]
  complaints Complaint[]
  users      User[]
}

model Category {
  id           String            @id @default(uuid())
  name         String            @unique
  departmentId String
  department   Department        @relation(fields: [departmentId], references: [id])
  complaints   Complaint[]
  slaConfig    SlaConfiguration?

  @@index([departmentId])
}

model SlaConfiguration {
  id               String   @id @default(uuid())
  categoryId       String   @unique
  resolveHours     Int
  escalationTarget Role
  priorityRules    Json
  updatedAt        DateTime @updatedAt
  category         Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
}

model Complaint {
  id           String                 @id @default(uuid())
  complaintNo  String                 @unique
  title        String
  description  String
  status       ComplaintStatus        @default(PENDING)
  priority     Priority               @default(MEDIUM)
  isOverdue    Boolean                @default(false)
  address      String
  latitude     Float?
  longitude    Float?
  ward         String?
  zone         String?
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  assignedAt   DateTime?
  resolvedAt   DateTime?
  closedAt     DateTime?
  slaBreachAt  DateTime?
  deletedAt    DateTime?
  citizenId    String
  officerId    String?
  districtId   String
  departmentId String?
  categoryId   String
  category     Category               @relation(fields: [categoryId], references: [id])
  citizen      User                   @relation("CitizenComplaints", fields: [citizenId], references: [id])
  department   Department?            @relation(fields: [departmentId], references: [id])
  district     District               @relation(fields: [districtId], references: [id])
  officer      User?                  @relation("OfficerComplaints", fields: [officerId], references: [id])
  events       ComplaintEvent[]
  verification ComplaintVerification?
  escalations  Escalation[]
  media        Media[]

  @@index([status, createdAt])
  @@index([districtId, status])
  @@index([departmentId, isOverdue])
  @@index([slaBreachAt])
  @@index([priority])
}

model ComplaintVerification {
  id          String             @id @default(uuid())
  complaintId String             @unique
  status      VerificationStatus @default(PENDING)
  feedback    String?
  rating      Int?
  verifiedAt  DateTime?
  createdAt   DateTime           @default(now())
  complaint   Complaint          @relation(fields: [complaintId], references: [id], onDelete: Cascade)
}

model Escalation {
  id              String    @id @default(uuid())
  complaintId     String
  escalatedFromId String
  escalatedToId   String
  reason          String
  createdAt       DateTime  @default(now())
  complaint       Complaint @relation(fields: [complaintId], references: [id], onDelete: Cascade)
  escalatedFrom   User      @relation("EscalatedFrom", fields: [escalatedFromId], references: [id])
  escalatedTo     User      @relation("EscalatedTo", fields: [escalatedToId], references: [id])

  @@index([complaintId])
}

model ComplaintEvent {
  id          String           @id @default(uuid())
  action      String
  oldStatus   ComplaintStatus?
  newStatus   ComplaintStatus?
  comments    String?
  complaintId String
  actorId     String
  createdAt   DateTime         @default(now())
  actor       User             @relation(fields: [actorId], references: [id])
  complaint   Complaint        @relation(fields: [complaintId], references: [id], onDelete: Cascade)
}

model Media {
  id           String    @id @default(uuid())
  url          String
  publicId     String
  type         MediaType
  complaintId  String
  uploadedById String
  createdAt    DateTime  @default(now())
  complaint    Complaint @relation(fields: [complaintId], references: [id], onDelete: Cascade)
  uploadedBy   User      @relation(fields: [uploadedById], references: [id])
}

model AuditLog {
  id         String   @id @default(uuid())
  actorId    String
  action     String
  entityType String
  entityId   String
  details    Json
  ipAddress  String?
  timestamp  DateTime @default(now())
  actor      User     @relation(fields: [actorId], references: [id])

  @@index([entityType, entityId])
  @@index([timestamp])
}

model Notification {
  id         String           @id @default(uuid())
  userId     String
  type       NotificationType
  title      String
  message    String
  isRead     Boolean          @default(false)
  linkTarget String?
  createdAt  DateTime         @default(now())
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
}

model OtpVerification {
  id        String   @id @default(uuid())
  phone     String?
  userId    String?
  otpHash   String
  expiresAt DateTime
  isUsed    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([phone, isUsed])
  @@index([userId, isUsed])
}

model AnalyticsSnapshot {
  id                       String   @id @default(uuid())
  timestamp                DateTime @default(now())
  totalComplaints          Int
  resolved                 Int
  inProgress               Int
  overdue                  Int
  districtMetrics          Json
  departmentMetrics        Json
  categoryMetrics          Json
  resolutionTrends         Json
  averageRating            Float?
  citizenSatisfactionScore Float?
  verificationApprovalRate Float?
  officerMetrics           Json?

  @@index([timestamp])
}

enum Role {
  CITIZEN
  FIELD_OFFICER
  OPERATIONS
  DEPARTMENT_HEAD
  CHIEF_MINISTER
  SUPER_ADMIN
}

enum ComplaintStatus {
  PENDING
  UNDER_REVIEW
  ASSIGNED
  IN_PROGRESS
  RESOLVED
  VERIFICATION_PENDING
  CLOSED
  REOPENED
  REJECTED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum NotificationType {
  STATUS_UPDATE
  ASSIGNMENT
  SLA_BREACH
  ESCALATION
  CITIZEN_FEEDBACK
  SYSTEM_ALERT
}

enum MediaType {
  CITIZEN_EVIDENCE
  OFFICER_PROOF
  BEFORE_PHOTO
  AFTER_PHOTO
}
